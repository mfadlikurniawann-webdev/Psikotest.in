# ============================================
# Psikotest.in — Environment Variables
# ============================================

# Database (Neon.tech PostgreSQL)
# Format 1: Connection string (recommended)
DATABASE_URL=postgresql://username:password@ep-xxxx.ap-southeast-1.aws.neon.tech/psikotest?sslmode=require

# Format 2: Individual params (alternative)
# DB_HOST=ep-xxxx.ap-southeast-1.aws.neon.tech
# DB_PORT=5432
# DB_DATABASE=psikotest
# DB_USERNAME=psikotest_owner
# DB_PASSWORD=your_password

# JWT Secret (min. 32 characters, generate random string)
JWT_SECRET=ganti-dengan-string-acak-minimal-32-karakter-untuk-keamanan

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
